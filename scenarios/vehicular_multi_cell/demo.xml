<config>
    <!-- Cellular interfaces for dynamically created cars and gNBs. -->
    <interface hosts="gNodeB*" names="cellular" address="10.x.x.x" netmask="255.0.0.0"/>
    <interface hosts="car*" names="cellular" address="10.x.x.x" netmask="255.0.0.0"/>

    <!-- All wired interfaces use a different subnet family. -->
    <interface hosts="**" address="192.168.x.x" netmask="255.255.255.0"/>
</config>
