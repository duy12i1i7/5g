+void UeStatsCollector::detachFromBaseStationCollector()
+{
+    if (detachedFromBaseStationCollector_ || binder_ == nullptr || nodeId_ == NODEID_NONE)
+        return;
+
+    binder_->removeUeCollectorFromEnodeB(nodeId_);
+    detachedFromBaseStationCollector_ = true;
+}
