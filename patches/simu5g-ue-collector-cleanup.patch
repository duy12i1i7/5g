+
+bool Binder::removeUeCollectorFromEnodeB(MacNodeId ue)
+{
+    EV << "LteBinder::removeUeCollector" << endl;
+
+    for (auto& enbInfo : enbList_) {
+        cModule *enb = enbInfo->eNodeB;
+        if (enb->getSubmodule("collector") == nullptr) {
+            continue;
+        }
+
+        BaseStationStatsCollector *enbColl = check_and_cast<BaseStationStatsCollector *>(enb->getSubmodule("collector"));
+        if (!enbColl->hasUeCollector(ue)) {
+            continue;
+        }
+
+        enbColl->removeUeCollector(ue);
+        EV << "LteBinder::removeUeCollector - UeCollector for node [" << ue << "] removed from eNodeB [" << enbInfo->id << "]" << endl;
+        return true;
     }
+
+    EV << "LteBinder::removeUeCollector - UeCollector for node [" << ue << "] was not registered in any eNodeB/gNodeB collector" << endl;
+    return false;
 }
 
