+void BaseStationStatsCollector::pruneInactiveUeCollectors()
+{
+    if (binder_ == nullptr)
+        return;
+
+    for (auto it = ueCollectors_.begin(); it != ueCollectors_.end(); ) {
+        if (binder_->getOmnetId(it->first) != 0) {
+            ++it;
+            continue;
+        }
+
+        EV << collectorType_ << "::pruneInactiveUeCollectors - removing inactive UE collector for node id: " << it->first << endl;
+        if (packetFlowManager_ != nullptr)
+            packetFlowManager_->deleteUe(it->first);
+        it = ueCollectors_.erase(it);
     }
 }
 
