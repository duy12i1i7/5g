# Pinned dependency matrix for the baseline stack.
# The selected versions are the most conservative overlap between:
# - Simu5G v1.3.1 compatibility notes (OMNeT++ 6.1.0, INET 4.5.4)
# - Veins 5.3.1 compatibility notes (OMNeT++ 6.1.0/6.0.3, INET 4.5.4)
# - Simu5G vehicular support via the "Simu5G Cars" feature

OMNETPP_VERSION=6.1.0
OMNETPP_REF=omnetpp-6.1.0
OMNETPP_GIT_URL=https://github.com/omnetpp/omnetpp.git

INET_VERSION=4.5.4
INET_REF=v4.5.4
INET_GIT_URL=https://github.com/inet-framework/inet.git

SIMU5G_VERSION=1.3.1
SIMU5G_REF=v1.3.1
SIMU5G_GIT_URL=https://github.com/Unipisa/Simu5G.git

VEINS_VERSION=5.3.1
VEINS_REF=veins-5.3.1
VEINS_GIT_URL=https://github.com/sommer/veins.git
VEINS_INET_SUBPROJECT=subprojects/veins_inet

# SUMO is used as an external executable for stage 2 vehicular mobility.
# The baseline expects a system or user install discoverable via `sumo` or SUMO_HOME.
SUMO_VERSION=1.22.0

