# Benchmark suites used by run_suite.sh.
# Keep the values space-separated so they can be expanded into bash arrays.

MINIMAL_PRESETS="MinimalUlLight MinimalUlHeavy"
VEHICULAR_PRESETS="VehicularSingleCellSafety VehicularSingleCellMixed VehicularMultiCellMixed VehicularMultiCellDense VehicularMultiCellMec VehicularMultiCellMecStress"
QUICK_PRESETS="MinimalUlLight VehicularSingleCellSafety VehicularMultiCellMixed"
FULL_PRESETS="${MINIMAL_PRESETS} ${VEHICULAR_PRESETS}"
